#!/bin/bash
set -e

# ============================================================
# MIM-Ops Pipeline - Allrun
# interFoam runner for OpenFOAM 2312
# ============================================================

CASE_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$CASE_DIR"

# ---------- 파라미터 (환경변수 또는 기본값) ----------
VELOCITY="${VELOCITY:-2.5}"
VISCOSITY="${VISCOSITY:-1e-6}"
END_TIME="${END_TIME:-5}"

echo "[Allrun] Cleaning case..."
rm -rf processor* logs postProcessing
find . -maxdepth 1 -regextype posix-extended -regex '\./[0-9]+\.[0-9]+' -type d -exec rm -rf {} + 2>/dev/null || true

echo "[Allrun] Velocity=${VELOCITY} | Viscosity=${VISCOSITY} | EndTime=${END_TIME}"

mkdir -p logs

# ---------- controlDict 생성 ----------
cat > system/controlDict << EOF
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}

application     interFoam;

startFrom       startTime;
startTime       0;

stopAt          endTime;
endTime         ${END_TIME};

deltaT          0.0001;

writeControl    adjustableRunTime;
writeInterval   0.1;

purgeWrite      0;
writeFormat     ascii;
writePrecision  6;
writeCompression off;

timeFormat      general;
timePrecision   6;

runTimeModifiable true;

adjustTimeStep  yes;
maxCo           0.5;
maxAlphaCo      0.5;
maxDeltaT       1;

// ************************************************************************* //
EOF

echo "[Allrun] controlDict created"

echo "=============================="
echo "[DEBUG] controlDict CONTENT"
echo "=============================="
cat -n system/controlDict
echo "=============================="
echo "[DEBUG] controlDict HASH"
md5sum system/controlDict

# ---------- 0/ 필드에 파라미터 치환 ----------
sed -i "s|VELOCITY_PLACEHOLDER|${VELOCITY}|g" 0/U
sed -i "s|uniform ([0-9e.+-]* 0 0)|uniform (${VELOCITY} 0 0)|g" 0/U

sed -i "s|VISCOSITY_PLACEHOLDER|${VISCOSITY}|g" constant/transportProperties

echo "[Allrun] 0/ fields ready"

# ---------- blockMesh ----------
echo "[Allrun] Running blockMesh..."
blockMesh 2>&1 | tee logs/blockMesh.log

# ---------- setFields (있을 경우만) ----------
if [ -f "system/setFieldsDict" ]; then
    echo "[Allrun] Running setFields..."
    setFields 2>&1 | tee logs/setFields.log
fi

# ---------- interFoam ----------
echo "[Allrun] Running interFoam..."
interFoam 2>&1 | tee logs/interFoam.log

# ---------- 결과 검증 ----------
echo "===== interFoam tail ====="
tail -20 logs/interFoam.log

TIMESTEPS=$(find . -maxdepth 1 -regextype posix-extended -regex '\./[0-9]+\.[0-9]+' -type d | wc -l)
echo "CHECK: Found ${TIMESTEPS} timestep folders"

if [ "$TIMESTEPS" -eq 0 ]; then
    echo "ERROR: No timesteps generated"
    exit 1
else
    echo "[Allrun] SUCCESS: ${TIMESTEPS} timestep(s) written"
fi
