#!/bin/bash
cd "${0%/*}" || exit

# 1. 초기화 (이전 해석 결과 및 통합 폴더 삭제)
echo "Cleaning old simulation data and folders..."
rm -rf [1-9]* 0.* log.* simulation.log results
mkdir -p results

# 2. 초기 조건 설정
[ -d "0.orig" ] && cp -r 0.orig 0

# 3. 격자 생성 및 해석 (interFoam)
echo "Generating Mesh (blockMesh & snappyHexMesh)..."
blockMesh > log.blockMesh 2>&1
snappyHexMesh -overwrite > log.snappyHexMesh 2>&1

echo "Running interFoam simulation..."
unset application
interFoam > simulation.log 2>&1

# 4. 후처리 준비 (ParaView)
echo "Preparing post-processing..."
touch case.foam

# yml에서 전달된 PVPYTHON_PATH가 없을 경우 기본값 설정
if [ -z "$PVPYTHON_PATH" ]; then
    PVPYTHON_PATH="/usr/bin/pvpython"
fi

# 5. 후처리 실행 (스크린샷 5장 + 3D VTP 데이터 추출)
if [ -f "export_screenshots.py" ]; then
    echo "Running pvpython post-processing with $PVPYTHON_PATH..."
    
    # 컨테이너 내부 라이브러리 경로 강제 지정
    export PYTHONPATH=$PYTHONPATH:/usr/lib/python3/dist-packages
    export LD_LIBRARY_PATH=$LD_LIBRARY_PATH:/usr/lib/x86_64-linux-gnu
    
    # 파이썬 스크립트 실행
    $PVPYTHON_PATH export_screenshots.py > log.pvpython 2>&1
    
    # 결과 확인을 위한 로그 출력
    echo "Post-processing complete. Checking results in results/ folder..."
    ls -la results/
else
    echo "Error: export_screenshots.py not found in the case directory!"
    exit 1
fi

echo "All processes finished successfully."
