#!/bin/bash
set -e

# ---------- Parameters from Environment ----------
VELOCITY="${VELOCITY:-0.05}"
VISCOSITY="${VISCOSITY:-1e-3}"
END_TIME="${END_TIME:-0.1}"

echo "Starting MIM-Ops Pipeline: V=$VELOCITY, nu=$VISCOSITY, EndTime=$END_TIME"

# 1. Clean previous results
rm -rf 0.[0-9]* [1-9]* postProcessing constant/polyMesh
mkdir -p results logs

# 2. Verify OpenFOAM environment
if ! command -v blockMesh &> /dev/null; then
    echo "Error: OpenFOAM commands not found. Check your environment sourcing."
    exit 1
fi

# 3. STL Pre-processing
if [ -f "constant/triSurface/part.stl" ]; then
    echo "STL detected. Scaling and Mesh generation starting..."
    surfaceTransformPoints -scale '(0.001 0.001 0.001)' \
        constant/triSurface/part.stl constant/triSurface/part.stl
    
    surfaceFeatureExtract
    blockMesh
    snappyHexMesh -overwrite
    checkMesh > logs/mesh_check.log
else
    echo "No STL found. Using default blockMesh geometry."
    blockMesh
fi

# 4. Dynamic Configuration
cat <<EOF > system/controlDict
FoamFile { version 2.0; format ascii; class dictionary; location "system"; object controlDict; }
application     interFoam;
startFrom       startTime;
startTime       0;
stopAt          endTime;
endTime         ${END_TIME};
deltaT          1e-05;
adjustTimeStep  yes;
maxCo           0.2;
maxAlphaCo      0.2;
maxDeltaT       1;
writeControl    adjustableRunTime;
writeInterval   0.05;
EOF

sed -i 's/Gauss linear/Gauss upwind/g' system/fvSchemes

# 5. Run Solver
interFoam | tee logs/solver.log

# 6. Export Results
cp -r postProcessing results/ 2>/dev/null || true
echo "Simulation Finished Successfully."
