#!/bin/bash
cd "${0%/*}" || exit

# 1. 환경 정리
rm -rf [1-9]* 0.* log.* simulation.log screenshots
mkdir -p screenshots

# 2. 초기 조건
[ -d "0.orig" ] && cp -r 0.orig 0

# 3. 격자 및 해석
blockMesh > log.blockMesh 2>&1
snappyHexMesh -overwrite > log.snappyHexMesh 2>&1

unset application
interFoam > simulation.log 2>&1

# 4. 후처리 (ParaView)
# .foam 파일이 있어야 ParaView가 데이터를 읽을 수 있습니다.
touch case.foam

if [ -f "export_screenshots.py" ]; then
    echo "Running post-processing..."
    # yml에서 xvfb-run을 썼으므로 여기선 직접 실행
    pvpython export_screenshots.py > log.pvpython 2>&1
else
    echo "export_screenshots.py not found"
fi

# 5. 최종 확인용
ls -la screenshots/
