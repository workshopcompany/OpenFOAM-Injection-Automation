#!/bin/bash
cd "${0%/*}" || exit

# ======================================================
# [0] 외부 변수 수신 (GitHub Actions ENV → OpenFOAM 파일)
# ======================================================
VELOCITY=${INPUT_VELOCITY:-2.5}
VISCOSITY=${INPUT_VISCOSITY:-1e-6}
END_TIME=${INPUT_END_TIME:-5}
RUN_LABEL=${INPUT_RUN_LABEL:-"auto-run"}

echo "[Allrun] === Run Config ==="
echo "  Velocity  : $VELOCITY m/s"
echo "  Viscosity : $VISCOSITY m2/s"
echo "  End Time  : $END_TIME s"
echo "  Label     : $RUN_LABEL"
echo "=========================="

# ======================================================
# [1] OpenFOAM 설정 파일에 변수 주입
# ======================================================

# inlet velocity → 0/U 파일
cat > 0/U << EOF
FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    location    "0";
    object      U;
}
dimensions      [0 1 -1 0 0 0 0];
internalField   uniform (0 0 0);
boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform ($VELOCITY 0 0);
    }
    outlet
    {
        type            zeroGradient;
    }
    walls
    {
        type            noSlip;
    }
    atmosphere
    {
        type            pressureInletOutletVelocity;
        value           uniform (0 0 0);
    }
    bottom
    {
        type            noSlip;
    }
}
EOF
echo "[Allrun] 0/U injected: inlet velocity = $VELOCITY m/s"

# viscosity → constant/transportProperties
cat > constant/transportProperties << EOF
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      transportProperties;
}
phases (water air);
water
{
    transportModel  Newtonian;
    nu              $VISCOSITY;
    rho             1000;
}
air
{
    transportModel  Newtonian;
    nu              1.48e-05;
    rho             1;
}
sigma           0.07;
EOF
echo "[Allrun] transportProperties injected: nu = $VISCOSITY"

# endTime → system/controlDict
sed -i "s/^endTime.*/endTime         $END_TIME;/" system/controlDict
echo "[Allrun] controlDict endTime set to $END_TIME"

# ======================================================
# [2] fvSolution / fvSchemes 강제 재생성
# ======================================================
cat > system/fvSolution << 'EOF'
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
solvers
{
    "alpha.water.*"
    {
        cAlpha          1;
        nAlphaCorr      1;
        nAlphaSubCycles 2;
        MULESCorr       yes;
        nLimiterIter    3;
        solver          smoothSolver;
        smoother        symGaussSeidel;
        tolerance       1e-8;
        relTol          0;
    }
    p_rgh        { solver PCG; preconditioner DIC; tolerance 1e-7; relTol 0.05; }
    p_rghFinal   { $p_rgh; relTol 0; }
    pcorr        { solver PCG; preconditioner DIC; tolerance 1e-5; relTol 0; }
    pcorrFinal   { $pcorr; relTol 0; }
    U            { solver smoothSolver; smoother symGaussSeidel; tolerance 1e-6; relTol 0; }
    UFinal       { $U; relTol 0; }
    k            { solver smoothSolver; smoother symGaussSeidel; tolerance 1e-6; relTol 0; }
    kFinal       { $k; relTol 0; }
    epsilon      { solver smoothSolver; smoother symGaussSeidel; tolerance 1e-6; relTol 0; }
    epsilonFinal { $epsilon; relTol 0; }
}
PIMPLE
{
    momentumPredictor   yes;
    nOuterCorrectors    1;
    nCorrectors         3;
    nNonOrthogonalCorrectors 0;
}
relaxationFactors { equations { ".*" 1; } }
EOF

cat > system/fvSchemes << 'EOF'
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSchemes;
}
ddtSchemes        { default Euler; }
gradSchemes       { default Gauss linear; grad(U) Gauss linear; }
divSchemes
{
    default                                     none;
    div(rhoPhi,U)                               Gauss linearUpwind grad(U);
    div(phi,alpha)                              Gauss vanLeer;
    div(phirb,alpha)                            Gauss linear;
    div(phi,k)                                  Gauss upwind;
    div(phi,epsilon)                            Gauss upwind;
    div(((rho*nuEff)*dev2(T(grad(U)))))         Gauss linear;
}
laplacianSchemes     { default Gauss linear corrected; }
interpolationSchemes { default linear; }
snGradSchemes        { default corrected; }
fluxRequired         { default no; p_rgh; pcorr; alpha.water; }
EOF

echo "[Allrun] fvSolution and fvSchemes regenerated."

# ======================================================
# [3] 초기화 및 blockMesh
# ======================================================
echo "[Allrun] Cleaning..."
rm -rf [1-9]* 0.* log.* results
mkdir -p results && chmod 777 results

echo "[Allrun] Running blockMesh..."
blockMesh > log.blockMesh 2>&1
echo "===== blockMesh Log ====="
cat log.blockMesh
echo "========================="

# ======================================================
# [4] interFoam
# ======================================================
echo "[Allrun] Running interFoam..."
interFoam > simulation.log 2>&1
echo "===== interFoam Log (last 30 lines) ====="
tail -30 simulation.log
echo "========================================="

TIMESTEP_COUNT=$(ls -d [0-9]* 2>/dev/null | grep -v "^0$" | wc -l)
echo "CHECK: Found $TIMESTEP_COUNT timestep folders"

if [ "$TIMESTEP_COUNT" -le 0 ]; then
    echo "ERROR: interFoam did not generate any time steps!"
    exit 1
fi

# 최대 압력/속도 추출 (리포트용)
MAX_U=$(grep "Max(U)" simulation.log | tail -1 | awk '{print $NF}' || echo "N/A")
MAX_P=$(grep "Max(p_rgh)" simulation.log | tail -1 | awk '{print $NF}' || echo "N/A")
echo "CHECK: Max velocity=$MAX_U, Max pressure=$MAX_P"

# ======================================================
# [5] 후처리 (스크린샷)
# ======================================================
echo "[Allrun] Starting Post-processing..."
touch case.foam

PVPY_EXE=${PVPYTHON_PATH:-/usr/bin/pvpython}
xvfb-run --auto-servernum --server-args="-screen 0 1280x1024x24" \
    $PVPY_EXE export_screenshots.py > log.pvpython 2>&1

echo "===== pvpython exit code: $? ====="
cat log.pvpython
echo "===== results ====="
ls -la results/

# ======================================================
# [6] 자동 리포트 생성 (report.md)
# ======================================================
TIMESTAMP=$(date -u +"%Y-%m-%d %H:%M UTC")
RESULT_IMAGES=$(ls results/*.png 2>/dev/null | wc -l)

cat > results/report.md << REPORT
# MIM-Flow Analyzer — Simulation Report

**Run Label:** $RUN_LABEL  
**Timestamp:** $TIMESTAMP  

## Input Parameters
| Parameter | Value |
|-----------|-------|
| Inlet Velocity | ${VELOCITY} m/s |
| Kinematic Viscosity | ${VISCOSITY} m²/s |
| Simulation End Time | ${END_TIME} s |

## Results Summary
| Metric | Value |
|--------|-------|
| Timesteps Generated | ${TIMESTEP_COUNT} |
| Screenshots Exported | ${RESULT_IMAGES} |
| Max Velocity | ${MAX_U} |
| Max Pressure | ${MAX_P} |

## Visualizations
$(for img in results/step_*.png; do
    fname=$(basename $img)
    echo "![${fname}](${fname})"
done)

---
*Auto-generated by MIM-Flow Analyzer | Materials-Ops Portfolio*
REPORT

echo "[Allrun] report.md generated."
echo "[Allrun] All done."
