#!/bin/bash
set -e

# ---------- Parameters ----------
VELOCITY="${VELOCITY:-0.05}"
VISCOSITY="${VISCOSITY:-1e-3}"
END_TIME="${END_TIME:-0.1}"

echo "==========================================="
echo " MIM-Ops LOG: Simulation Started"
echo " Time: $(date)"
echo " Params: V=$VELOCITY, nu=$VISCOSITY, End=$END_TIME"
echo "==========================================="

# 1. Directory Setup
mkdir -p results logs
echo ">>> [STEP 1] Cleaning previous data..."
rm -rf 0.[0-9]* [1-9]* postProcessing constant/polyMesh

# 2. STL & Mesh Processing
if [ -f "constant/triSurface/part.stl" ]; then
    echo ">>> [STEP 2] STL found. Scaling mm to m..."
    surfaceTransformPoints -scale '(0.001 0.001 0.001)' \
        constant/triSurface/part.stl constant/triSurface/part.stl > logs/scale.log 2>&1
    
    echo ">>> [STEP 3] Extracting features & Meshing..."
    surfaceFeatureExtract > logs/extract.log 2>&1
    blockMesh > logs/blockMesh.log 2>&1
    snappyHexMesh -overwrite > logs/snappy.log 2>&1
    echo ">>> Mesh generation complete."
else
    echo ">>> [STEP 2] No STL. Using default blockMesh..."
    blockMesh > logs/blockMesh.log 2>&1
fi

# 3. Dynamic Configuration (Safety Guards)
echo ">>> [STEP 4] Writing dynamic controlDict..."
cat <<EOF > system/controlDict
FoamFile { version 2.0; format ascii; class dictionary; location "system"; object controlDict; }
application     interFoam;
startFrom       startTime;
startTime       0;
stopAt          endTime;
endTime         ${END_TIME};
deltaT          1e-05;
adjustTimeStep  yes;
maxCo           0.2;
maxAlphaCo      0.2;
writeControl    adjustableRunTime;
writeInterval   0.05;
EOF

if [ -f "system/fvSchemes" ]; then
    sed -i 's/Gauss linear/Gauss upwind/g' system/fvSchemes
fi

# 4. Main Solver Execution
echo ">>> [STEP 5] Running interFoam solver (This may take time)..."
if interFoam > logs/solver.log 2>&1; then
    echo "✅ [SUCCESS] Solver finished normally."
else
    echo "❌ [ERROR] Solver crashed. Check logs/solver.log"
    exit 1
fi

# 5. Exporting Results
echo ">>> [STEP 6] Exporting results to results/ folder..."
if [ -d "postProcessing" ]; then
    cp -r postProcessing results/
fi

echo "==========================================="
echo " MIM-Ops LOG: Simulation Finished Successfully"
echo " Time: $(date)"
echo "==========================================="
