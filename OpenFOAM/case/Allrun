#!/bin/bash
cd "${0%/*}" || exit

# ======================================================
# [0] 초기 클린 (🔥 가장 먼저!)
# ======================================================
echo "[Allrun] Cleaning..."
rm -rf [1-9]* log.* results
rm -rf 0
mkdir -p 0 results
chmod 777 results

# ======================================================
# [1] 외부 변수 수신
# ======================================================
VELOCITY=${INPUT_VELOCITY:-2.5}
VISCOSITY=${INPUT_VISCOSITY:-1e-6}
END_TIME=${INPUT_END_TIME:-5}
RUN_LABEL=${INPUT_RUN_LABEL:-"auto-run"}

echo "[Allrun] === Run Config ==="
echo "  Velocity  : $VELOCITY m/s"
echo "  Viscosity : $VISCOSITY m2/s"
echo "  End Time  : $END_TIME s"
echo "  Label     : $RUN_LABEL"
echo "=========================="

# ======================================================
# [2] 0/ 초기조건 생성 (🔥 필수 3종)
# ======================================================

# ---- U ----
cat > 0/U << EOF
FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    location    "0";
    object      U;
}
dimensions      [0 1 -1 0 0 0 0];
internalField   uniform (0 0 0);
boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform ($VELOCITY 0 0);
    }
    outlet
    {
        type            zeroGradient;
    }
    walls
    {
        type            noSlip;
    }
    atmosphere
    {
        type            pressureInletOutletVelocity;
        value           uniform (0 0 0);
    }
    bottom
    {
        type            noSlip;
    }
}
EOF

# ---- p_rgh ----
cat > 0/p_rgh << EOF
FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      p_rgh;
}
dimensions      [1 -1 -2 0 0 0 0];
internalField   uniform 0;
boundaryField
{
    inlet
    {
        type            fixedFluxPressure;
    }
    outlet
    {
        type            fixedValue;
        value           uniform 0;
    }
    walls
    {
        type            fixedFluxPressure;
    }
    atmosphere
    {
        type            totalPressure;
        p0              uniform 0;
    }
    bottom
    {
        type            fixedFluxPressure;
    }
}
EOF

# ---- alpha.water ----
cat > 0/alpha.water << EOF
FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      alpha.water;
}
dimensions      [0 0 0 0 0 0 0];
internalField   uniform 0;
boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform 1;
    }
    outlet
    {
        type            zeroGradient;
    }
    walls
    {
        type            zeroGradient;
    }
    atmosphere
    {
        type            inletOutlet;
        inletValue      uniform 0;
        value           uniform 0;
    }
    bottom
    {
        type            zeroGradient;
    }
}
EOF

echo "[Allrun] 0/ fields generated."

# ======================================================
# [3] transportProperties
# ======================================================
cat > constant/transportProperties << EOF
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      transportProperties;
}
phases (water air);

water
{
    transportModel  Newtonian;
    nu              $VISCOSITY;
    rho             1000;
}

air
{
    transportModel  Newtonian;
    nu              1.48e-05;
    rho             1;
}

sigma           0.07;
EOF

echo "[Allrun] transportProperties set."

# ======================================================
# [4] controlDict 수정
# ======================================================
sed -i "s/^endTime.*/endTime         $END_TIME;/" system/controlDict

# ======================================================
# [5] fvSolution / fvSchemes
# ======================================================
cat > system/fvSolution << 'EOF'
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
solvers
{
    "alpha.water.*"
    {
        solver smoothSolver;
        smoother symGaussSeidel;
        tolerance 1e-8;
        relTol 0;
    }
    p_rgh { solver PCG; preconditioner DIC; tolerance 1e-7; relTol 0.05; }
    U { solver smoothSolver; smoother symGaussSeidel; tolerance 1e-6; relTol 0; }
}
PIMPLE
{
    nOuterCorrectors 1;
    nCorrectors 2;
}
EOF

cat > system/fvSchemes << 'EOF'
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSchemes;
}
ddtSchemes        { default Euler; }
gradSchemes       { default Gauss linear; }
divSchemes
{
    default none;
    div(rhoPhi,U) Gauss linearUpwind grad(U);
    div(phi,alpha) Gauss vanLeer;
}
laplacianSchemes { default Gauss linear corrected; }
interpolationSchemes { default linear; }
snGradSchemes { default corrected; }
EOF

echo "[Allrun] fv files generated."

# ======================================================
# [6] mesh
# ======================================================
echo "[Allrun] Running blockMesh..."
blockMesh > log.blockMesh 2>&1
tail -20 log.blockMesh

# ======================================================
# [7] solver
# ======================================================
echo "[Allrun] Running interFoam..."
interFoam > simulation.log 2>&1

echo "===== interFoam tail ====="
tail -30 simulation.log

# ======================================================
# [8] 결과 확인
# ======================================================
TIMESTEP_COUNT=$(ls -d [0-9]* 2>/dev/null | grep -v "^0$" | wc -l)
echo "CHECK: Found $TIMESTEP_COUNT timestep folders"

if [ "$TIMESTEP_COUNT" -le 0 ]; then
    echo "ERROR: No timesteps generated"
    exit 1
fi

echo "[Allrun] SUCCESS"
