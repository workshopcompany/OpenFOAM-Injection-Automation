#!/bin/bash
cd "${0%/*}" || exit

# 1. 초기화
echo "Step 1: Cleaning and preparing results folder..."
rm -rf [1-9]* 0.* log.* simulation.log results
mkdir -p results
chmod 777 results

# 2. 초기 조건 설정
[ -d "0.orig" ] && cp -r 0.orig 0

# 3. 격자 및 해석
echo "Step 2: Mesh generation..."
blockMesh > log.blockMesh 2>&1
snappyHexMesh -overwrite > log.snappyHexMesh 2>&1

echo "Step 3: Running interFoam..."
unset application
interFoam > simulation.log 2>&1

# 4. 후처리 준비 (환경변수는 yml에서 이미 선언했으나 이중 보완)
echo "Step 4: Preparing Post-processing..."
touch case.foam

# 5. 후처리 실행
if [ -f "export_screenshots.py" ]; then
    echo "Running pvpython post-processing..."
    # 중복 실행 제거: 변수 확인 후 단 한 번만 실행
    PVPY_EXE=${PVPYTHON_PATH:-/usr/bin/pvpython}
    
    # 가상 디스플레이(xvfb-run) 내부에서 호출되므로 바로 실행
    $PVPY_EXE export_screenshots.py > log.pvpython 2>&1
    
    # 결과 요약 보고
    echo "===== Post-processing Complete ====="
    FILE_COUNT=$(ls -1 results/ | wc -l)
    echo "Total files in results/: $FILE_COUNT"
    ls -la results/
else
    echo "Error: export_screenshots.py not found"
    exit 1
fi

echo "All processes finished successfully."
