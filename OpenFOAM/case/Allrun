#!/bin/bash
set -e

# ── 1. 환경 설정 및 변수 로드 ──────────────────────────────
CASE_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$CASE_DIR"

# 파라미터가 환경 변수로 들어오지 않았을 경우를 대비한 기본값 (MIM 17-4PH 기준)
VELOCITY="${VELOCITY:-0.025}"
VISCOSITY="${VISCOSITY:-4e-3}"
DENSITY="${DENSITY:-7780}"
END_TIME="${END_TIME:-0.5}"
MATERIAL="${MATERIAL:-17-4PH}"

echo ">>> [MIM-Ops] Simulation Started" | tee -a logs/pipeline.log
echo ">>> [Parameters] Material=${MATERIAL} | V=${VELOCITY} | nu=${VISCOSITY} | rho=${DENSITY}"

mkdir -p logs results

# ── 2. 이전 데이터 및 환경 정리 ───────────────────────────
if ! command -v blockMesh &> /dev/null; then
    echo "❌ ERROR: blockMesh command not found. Environment source failed!" | tee -a logs/pipeline.log
    exit 1
fi

rm -rf 0.[0-9]* [1-9]* postProcessing constant/polyMesh 2>/dev/null
rm -rf results/* logs/*

# ── 3. OpenFOAM 필수 딕셔너리 생성 (간소화 방지) ───────────

# [controlDict] - 시뮬레이션 제어
cat > system/controlDict << DICT_EOF
FoamFile { version 2.0; format ascii; class dictionary; location "system"; object controlDict; }
application     interFoam;
startFrom       startTime;
startTime       0;
stopAt          endTime;
endTime         ${END_TIME};
deltaT          0.0001;
writeControl    adjustableRunTime;
writeInterval   0.05;
purgeWrite      0;
writeFormat     ascii;
writePrecision  6;
writeCompression off;
timeFormat      general;
timePrecision   6;
runTimeModifiable true;
adjustTimeStep  yes;
maxCo           0.5;
maxAlphaCo      0.5;
maxDeltaT       0.01;
DICT_EOF

# [transportProperties] - 2상 유동(물/공기) 물성
cat > constant/transportProperties << TP_EOF
FoamFile { version 2.0; format ascii; class dictionary; location "constant"; object transportProperties; }
phases (water air);
water {
    transportModel  Newtonian;
    nu              [0 2 -1 0 0 0 0] ${VISCOSITY};
    rho             [1 -3 0 0 0 0 0] ${DENSITY};
}
air {
    transportModel  Newtonian;
    nu              [0 2 -1 0 0 0 0] 1.48e-5;
    rho             [1 -3 0 0 0 0 0] 1.2;
}
sigma           [1 0 -2 0 0 0 0] 0.07;
TP_EOF

# [fvSchemes] - 수치 해석 스킴
cat > system/fvSchemes << FS_EOF
FoamFile { version 2.0; format ascii; class dictionary; location "system"; object fvSchemes; }
ddtSchemes      { default Euler; }
gradSchemes     { default Gauss linear; }
divSchemes {
    default                             none;
    div(phi,alpha.water)                Gauss vanLeer;
    div(phi,U)                          Gauss linearUpwind grad(U);
    div(phi,alpha)                      Gauss vanLeer;
    div(phirb,alpha.water)              Gauss linear;
    div(((rho*nuEff)*dev2(T(grad(U))))) Gauss linear;
}
laplacianSchemes { default Gauss linear corrected; }
interpolationSchemes { default linear; }
snGradSchemes   { default corrected; }
FS_EOF

# [fvSolution] - 솔버 알고리즘 설정
cat > system/fvSolution << FSO_EOF
FoamFile { version 2.0; format ascii; class dictionary; location "system"; object fvSolution; }
solvers {
    "alpha.water.*" { solver smoothSolver; smoother symGaussSeidel; tolerance 1e-8; relTol 0; nAlphaCorr 2; nAlphaSubCycles 1; }
    p_rgh { solver GAMG; smoother GaussSeidel; tolerance 1e-7; relTol 0.05; }
    p_rghFinal { \$p_rgh; relTol 0; }
    U { solver smoothSolver; smoother symGaussSeidel; tolerance 1e-6; relTol 0; }
}
PIMPLE { momentumPredictor no; nOuterCorrectors 1; nCorrectors 3; nNonOrthogonalCorrectors 0; }
FSO_EOF

# ── 4. 초기 필드(0/) 생성 (interFoam 물리 단위 적용) ──────

mkdir -p 0
# p_rgh (물리적 압력 [1 -1 -2])
cat > 0/p_rgh << P_EOF
FoamFile { version 2.0; format ascii; class volScalarField; location "0"; object p_rgh; }
dimensions [1 -1 -2 0 0 0 0];
internalField uniform 0;
boundaryField {
    inlet { type fixedFluxPressure; value uniform 0; }
    outlet { type fixedValue; value uniform 0; }
    walls { type fixedFluxPressure; value uniform 0; }
    frontAndBack { type empty; }
}
P_EOF

# U (속도 [0 1 -1])
cat > 0/U << U_EOF
FoamFile { version 2.0; format ascii; class volVectorField; location "0"; object U; }
dimensions [0 1 -1 0 0 0 0];
internalField uniform (0 0 0);
boundaryField {
    inlet { type fixedValue; value uniform (${VELOCITY} 0 0); }
    outlet { type zeroGradient; }
    walls { type noSlip; }
    frontAndBack { type empty; }
}
U_EOF

# alpha.water (상분율 [0 0 0])
cat > 0/alpha.water << A_EOF
FoamFile { version 2.0; format ascii; class volScalarField; location "0"; object alpha.water; }
dimensions [0 0 0 0 0 0 0];
internalField uniform 0;
boundaryField {
    inlet { type fixedValue; value uniform 1; }
    outlet { type zeroGradient; }
    walls { type zeroGradient; }
    frontAndBack { type empty; }
}
A_EOF

# ── 5. Mesh & Scaling (기존 STL 로직 유지) ────────────────

if [ -f "constant/triSurface/part.stl" ]; then
    echo ">>> STL detected. Running Complex Mesh Pipeline..." | tee -a logs/pipeline.log
    surfaceTransformPoints -scale '(0.001 0.001 0.001)' \
        constant/triSurface/part.stl constant/triSurface/part.stl > logs/mesh.log 2>&1
    surfaceFeatureExtract >> logs/mesh.log 2>&1
    blockMesh >> logs/mesh.log 2>&1
    snappyHexMesh -overwrite >> logs/mesh.log 2>&1
else
    echo ">>> No STL. Running Basic blockMesh..." | tee -a logs/pipeline.log
    blockMesh > logs/mesh.log 2>&1
fi

# ── 6. Solver 실행 ─────────────────────────────────────────
echo ">>> Running interFoam..." | tee -a logs/pipeline.log
interFoam > logs/solver.log 2>&1 || { echo "❌ interFoam failed!"; tail -n 20 logs/solver.log; exit 1; }

# ── 7. 결과 정리 및 검증 ──────────────────────────────────
if [ -d "postProcessing" ]; then
    cp -r postProcessing results/
fi

# 마지막 타임스텝 확인
LAST_TIME=$(find . -maxdepth 1 -regextype posix-extended -regex '\./[0-9]+(\.[0-9]+)?' -type d | sort -n | tail -1 | sed 's/\.\///')

echo "✅ Simulation Finished. Last Timestep: ${LAST_TIME}" | tee -a logs/pipeline.log
