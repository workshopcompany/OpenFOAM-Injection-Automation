#!/bin/bash
cd "${0%/*}" || exit 1

# ======================================================
# [0] 초기 클린
# ======================================================
echo "[Allrun] Cleaning case..."
rm -rf [1-9]* log.* results
rm -rf 0
mkdir -p 0 results
chmod 777 results

# ======================================================
# [1] 변수 설정
# ======================================================
VELOCITY=${INPUT_VELOCITY:-2.5}
VISCOSITY=${INPUT_VISCOSITY:-1e-6}
END_TIME=${INPUT_END_TIME:-5}

echo "[Allrun] Velocity=$VELOCITY | Viscosity=$VISCOSITY | EndTime=$END_TIME"

# ======================================================
# [2] controlDict 강제 생성 (🔥 핵심)
# ======================================================
cat > system/controlDict << EOF
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}

application     interFoam;

startFrom       startTime;
startTime       0;

stopAt          endTime;
endTime         $END_TIME;

deltaT          0.0001;

writeControl    adjustableRunTime;
writeInterval   0.1;

purgeWrite      0;
writeFormat     ascii;
writePrecision  6;
writeCompression off;

timeFormat      general;
timePrecision   6;

runTimeModifiable true;

adjustTimeStep  yes;
maxCo           0.5;
maxAlphaCo      0.5;
maxDeltaT       1;

// ************************************************************************* //
EOF

echo "[Allrun] controlDict created"

# 🔥 덮어쓰기 방지
chmod 444 system/controlDict

# ======================================================
# [3] DEBUG: 실제 controlDict 확인
# ======================================================
echo "=============================="
echo "[DEBUG] controlDict CONTENT"
echo "=============================="
nl -ba system/controlDict
echo "=============================="

echo "[DEBUG] controlDict HASH"
md5sum system/controlDict

# ======================================================
# [4] 초기조건 생성
# ======================================================

# U
cat > 0/U << EOF
FoamFile
{
    version 2.0;
    format ascii;
    class volVectorField;
    location "0";
    object U;
}
dimensions [0 1 -1 0 0 0 0];
internalField uniform (0 0 0);
boundaryField
{
    inlet { type fixedValue; value uniform ($VELOCITY 0 0); }
    outlet { type zeroGradient; }
    walls { type noSlip; }
    atmosphere { type pressureInletOutletVelocity; value uniform (0 0 0); }
    bottom { type noSlip; }
}
EOF

# p_rgh
cat > 0/p_rgh << EOF
FoamFile
{
    version 2.0;
    format ascii;
    class volScalarField;
    location "0";
    object p_rgh;
}
dimensions [1 -1 -2 0 0 0 0];
internalField uniform 0;
boundaryField
{
    inlet { type fixedFluxPressure; }
    outlet { type fixedValue; value uniform 0; }
    walls { type fixedFluxPressure; }
    atmosphere { type totalPressure; p0 uniform 0; }
    bottom { type fixedFluxPressure; }
}
EOF

# alpha.water
cat > 0/alpha.water << EOF
FoamFile
{
    version 2.0;
    format ascii;
    class volScalarField;
    location "0";
    object alpha.water;
}
dimensions [0 0 0 0 0 0 0];
internalField uniform 0;
boundaryField
{
    inlet { type fixedValue; value uniform 1; }
    outlet { type zeroGradient; }
    walls { type zeroGradient; }
    atmosphere { type inletOutlet; inletValue uniform 0; value uniform 0; }
    bottom { type zeroGradient; }
}
EOF

echo "[Allrun] 0/ fields created"

# ======================================================
# [5] 물성
# ======================================================
cat > constant/transportProperties << EOF
FoamFile
{
    version 2.0;
    format ascii;
    class dictionary;
    location "constant";
    object transportProperties;
}

phases (water air);

water
{
    transportModel Newtonian;
    nu $VISCOSITY;
    rho 1000;
}

air
{
    transportModel Newtonian;
    nu 1.48e-05;
    rho 1;
}

sigma 0.07;
EOF

# ======================================================
# [6] fvSolution
# ======================================================
cat > system/fvSolution << EOF
FoamFile
{
    version 2.0;
    format ascii;
    class dictionary;
    location "system";
    object fvSolution;
}
solvers
{
    "alpha.water.*"
    {
        solver smoothSolver;
        smoother symGaussSeidel;
        tolerance 1e-8;
        relTol 0;
    }
    p_rgh { solver PCG; preconditioner DIC; tolerance 1e-7; relTol 0.05; }
    U { solver smoothSolver; smoother symGaussSeidel; tolerance 1e-6; relTol 0; }
}
PIMPLE
{
    nOuterCorrectors 1;
    nCorrectors 2;
}
EOF

# ======================================================
# [7] fvSchemes
# ======================================================
cat > system/fvSchemes << EOF
FoamFile
{
    version 2.0;
    format ascii;
    class dictionary;
    location "system";
    object fvSchemes;
}
ddtSchemes { default Euler; }
gradSchemes { default Gauss linear; }
divSchemes
{
    default none;
    div(rhoPhi,U) Gauss linearUpwind grad(U);
    div(phi,alpha) Gauss vanLeer;
}
laplacianSchemes { default Gauss linear corrected; }
interpolationSchemes { default linear; }
snGradSchemes { default corrected; }
EOF

# ======================================================
# [8] mesh
# ======================================================
echo "[Allrun] Running blockMesh..."
blockMesh > log.blockMesh 2>&1
tail -20 log.blockMesh

# ======================================================
# [9] solver
# ======================================================
echo "[Allrun] Running interFoam..."
interFoam > simulation.log 2>&1

echo "===== interFoam tail ====="
tail -30 simulation.log

# ======================================================
# [10] 결과 확인
# ======================================================
TIMESTEP_COUNT=$(ls -d [0-9]* 2>/dev/null | grep -v "^0$" | wc -l)
echo "CHECK: Found $TIMESTEP_COUNT timestep folders"

if [ "$TIMESTEP_COUNT" -le 0 ]; then
    echo "ERROR: No timesteps generated"
    exit 1
fi

echo "[Allrun] SUCCESS"
