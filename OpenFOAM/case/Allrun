#!/bin/bash
cd "${0%/*}" || exit

# 1. 초기화
rm -rf [1-9]* 0.* log.* simulation.log screenshots
mkdir -p screenshots

# 2. 초기 조건
[ -d "0.orig" ] && cp -r 0.orig 0

# 3. 격자 및 해석 (interFoam)
blockMesh > log.blockMesh 2>&1
snappyHexMesh -overwrite > log.snappyHexMesh 2>&1

unset application
interFoam > simulation.log 2>&1

# 4. 후처리 (ParaView)
touch case.foam

# yml에서 설정한 경로가 있는지 확인
if [ -z "$PVPYTHON_PATH" ]; then
    PVPYTHON_PATH="/usr/bin/pvpython"
fi

if [ -f "export_screenshots.py" ]; then
    echo "Running post-processing with $PVPYTHON_PATH..."
    # 파이썬 경로를 다시 한 번 명시적으로 선언
    export PYTHONPATH=$PYTHONPATH:/usr/lib/python3/dist-packages
    
    $PVPYTHON_PATH export_screenshots.py > log.pvpython 2>&1
else
    echo "Error: export_screenshots.py not found"
    exit 1
fi

ls -la screenshots/
