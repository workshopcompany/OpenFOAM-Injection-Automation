name: OpenFOAM Simulation

on:
  push:
    branches: [ "main" ]
  workflow_dispatch:

jobs:
  run-sim:
    runs-on: ubuntu-latest
    env:
      FORCE_JAVASCRIPT_ACTIONS_TO_NODE24: true
    container: 
      image: opencfd/openfoam-run:2312
      options: --user root
    
    steps:
      - name: Checkout code
        uses: actions/checkout@v4
      
      - name: Install Post-Processing Dependencies
        run: |
          rm -f /etc/apt/sources.list.d/openfoam.list || true
          apt-get update
          apt-get install -y paraview python3-paraview xvfb libgl1-mesa-glx libglu1-mesa libxcursor1
      
      - name: Run OpenFOAM Simulation
        shell: bash
        working-directory: OpenFOAM/case
        run: |
          bash << 'SCRIPT_END'
          set -e
          source /usr/lib/openfoam/openfoam2312/etc/bashrc 2>/dev/null || true
          
          # 후처리 필수 환경 변수 강제 주입
          export PYTHONPATH=$PYTHONPATH:/usr/lib/python3/dist-packages
          export LD_LIBRARY_PATH=$LD_LIBRARY_PATH:/usr/lib/x86_64-linux-gnu
          export PVPYTHON_PATH=$(which pvpython || echo "/usr/bin/pvpython")
          
          # 결과 폴더 권한 부여 및 생성
          mkdir -p results
          chmod 777 results
          chmod +x Allrun
          
          echo "Starting Simulation..."
          xvfb-run --auto-servernum --server-args="-screen 0 1280x1024x24" ./Allrun
          
          echo "===== CRITICAL: WORKSPACE DEBUG ====="
          pwd
          ls -R results/
          cat log.pvpython || echo "log.pvpython is missing!"
          SCRIPT_END
      
      - name: Upload 3D Interactive Results
        uses: actions/upload-artifact@v4
        if: always()
        with:
          name: OpenFOAM-Web-Dashboard
          # 컨테이너 내 생성된 파일이 호스트 볼륨에 반영되었는지 확인하기 위해 와일드카드 사용
          path: "**/OpenFOAM/case/results/*"
          if-no-files-found: error
