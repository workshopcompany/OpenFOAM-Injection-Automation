#!/bin/bash
cd "${0%/*}" || exit

# 1~3 단계 (기존과 동일)
rm -rf [1-9]* 0.* log.* simulation.log screenshots
mkdir -p screenshots
[ -d "0.orig" ] && cp -r 0.orig 0
blockMesh > log.blockMesh 2>&1
snappyHexMesh -overwrite > log.snappyHexMesh 2>&1

# 4. 솔버 실행
unset application
interFoam > simulation.log 2>&1

# 5. 후처리 (pvpython 호출부 수정)
touch case.foam
if ls -d [0-9]* >/dev/null 2>&1; then
    echo "Running post-processing..."
    # 'pvpython' 명령어를 찾지 못하는 문제 해결을 위해 전체 경로 확인 후 실행
    CMD=$(which pvpython)
    if [ -z "$CMD" ]; then CMD="/usr/bin/pvpython"; fi
    
    $CMD export_screenshots.py > log.pvpython 2>&1
else
    echo "No results to process."
    exit 1
fi

ls -la screenshots/
