#!/bin/bash
cd "${0%/*}" || exit

# 1. 이전 결과 정리
rm -rf [1-9]* 0.* log.* simulation.log screenshots
mkdir -p screenshots

# 2. 초기 데이터 복사
[ -d "0.orig" ] && cp -r 0.orig 0

# 3. 격자 및 해석 실행
echo "Generating Mesh..."
blockMesh > log.blockMesh 2>&1
snappyHexMesh -overwrite > log.snappyHexMesh 2>&1

unset application
echo "Running interFoam..."
interFoam > simulation.log 2>&1

# 4. 후처리 (ParaView 스크린샷)
touch case.foam

# yml에서 전달한 PVPYTHON_BIN 변수가 없으면 기본값 사용
if [ -z "$PVPYTHON_BIN" ]; then
    PVPYTHON_BIN="pvpython"
fi

if [ -f "export_screenshots.py" ]; then
    echo "Running post-processing with $PVPYTHON_BIN..."
    # 5초 정도 해석 데이터가 써질 시간을 준 뒤 실행
    sleep 2
    $PVPYTHON_BIN export_screenshots.py > log.pvpython 2>&1
else
    echo "Error: export_screenshots.py not found"
    exit 1
fi

# 5. 최종 이미지 확인
ls -la screenshots/
