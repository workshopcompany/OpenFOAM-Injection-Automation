#!/bin/bash
cd "${0%/*}" || exit

# ======================================================
# fvSolution 강제 재생성 (파일 인코딩 문제 방지)
# ======================================================
cat > system/fvSolution << 'EOF'
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}

solvers
{
    "alpha.water.*"
    {
        cAlpha          1;
        nAlphaCorr      1;
        nAlphaSubCycles 2;
        MULESCorr       yes;
        nLimiterIter    3;
        solver          smoothSolver;
        smoother        symGaussSeidel;
        tolerance       1e-8;
        relTol          0;
    }
    p_rgh       { solver PCG; preconditioner DIC; tolerance 1e-7; relTol 0.05; }
    p_rghFinal  { $p_rgh; relTol 0; }
    pcorr       { solver PCG; preconditioner DIC; tolerance 1e-5; relTol 0; }
    pcorrFinal  { $pcorr; relTol 0; }
    U           { solver smoothSolver; smoother symGaussSeidel; tolerance 1e-6; relTol 0; }
    UFinal      { $U; relTol 0; }
    k           { solver smoothSolver; smoother symGaussSeidel; tolerance 1e-6; relTol 0; }
    kFinal      { $k; relTol 0; }
    epsilon     { solver smoothSolver; smoother symGaussSeidel; tolerance 1e-6; relTol 0; }
    epsilonFinal { $epsilon; relTol 0; }
}

PIMPLE
{
    momentumPredictor   yes;
    nOuterCorrectors    1;
    nCorrectors         3;
    nNonOrthogonalCorrectors 0;
}

relaxationFactors
{
    equations { ".*" 1; }
}
EOF

# fvSchemes도 동일하게 강제 재생성
cat > system/fvSchemes << 'EOF'
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSchemes;
}

ddtSchemes        { default Euler; }
gradSchemes       { default Gauss linear; grad(U) Gauss linear; }
divSchemes
{
    default                                     none;
    div(rhoPhi,U)                               Gauss linearUpwind grad(U);
    div(phi,alpha)                              Gauss vanLeer;
    div(phirb,alpha)                            Gauss linear;
    div(phi,k)                                  Gauss upwind;
    div(phi,epsilon)                            Gauss upwind;
    div(((rho*nuEff)*dev2(T(grad(U)))))         Gauss linear;
}
laplacianSchemes  { default Gauss linear corrected; }
interpolationSchemes { default linear; }
snGradSchemes     { default corrected; }
fluxRequired      { default no; p_rgh; pcorr; alpha.water; }
EOF

echo "[Allrun] fvSolution and fvSchemes regenerated successfully."

# ======================================================
# 이후 기존 로직 그대로
# ======================================================
echo "[Allrun] Cleaning and creating results folder..."
rm -rf [1-9]* 0.* log.* results
mkdir -p results && chmod 777 results

# blockMesh 실행 + 로그 즉시 출력
echo "[Allrun] Running blockMesh..."
blockMesh > log.blockMesh 2>&1
echo "===== blockMesh Log ====="
cat log.blockMesh
echo "========================="
[ ! -s log.blockMesh ] && echo "ERROR: blockMesh failed" && exit 1

# interFoam 실행 + 로그 즉시 출력
echo "[Allrun] Running interFoam..."
interFoam > simulation.log 2>&1
echo "===== interFoam Log (last 50 lines) ====="
tail -50 simulation.log
echo "========================================="

# 타임스텝 체크
TIMESTEP_COUNT=$(ls -d [0-9]* 2>/dev/null | grep -v "^0$" | wc -l)
echo "CHECK: Found $TIMESTEP_COUNT timestep folders"
ls -la

if [ "$TIMESTEP_COUNT" -le 0 ]; then
    echo "ERROR: interFoam did not generate any time steps!"
    exit 1
fi

# 후처리
echo "[Allrun] Starting Post-processing..."
touch case.foam
if [ -f "export_screenshots.py" ]; then
    PVPY_EXE=${PVPYTHON_PATH:-/usr/bin/pvpython}
    echo "Using: $PVPY_EXE"
    $PVPY_EXE export_screenshots.py > log.pvpython 2>&1
    echo "===== Post-processing Result Check ====="
    cat log.pvpython
    ls -la results/
    echo "========================================"
else
    echo "ERROR: export_screenshots.py missing!"
    exit 1
fi
