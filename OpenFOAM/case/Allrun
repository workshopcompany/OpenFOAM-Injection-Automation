#!/bin/bash
set -e

# Parameters
VELOCITY="${VELOCITY:-0.05}"
VISCOSITY="${VISCOSITY:-1e-3}"
END_TIME="${END_TIME:-0.1}"

echo ">>> [MIM-Ops] Checking basic files..."
mkdir -p results logs

# 1. Clean previous data
rm -rf 0.[0-9]* [1-9]* postProcessing constant/polyMesh

# 2. Check essential system files (Failure here causes Exit Code 1)
for file in system/fvSchemes system/fvSolution; do
    if [ ! -f "$file" ]; then
        echo "❌ Error: $file is missing! Simulation cannot start."
        exit 1
    fi
done

# 3. STL & Mesh
if [ -f "constant/triSurface/part.stl" ]; then
    echo ">>> STL scaling..."
    surfaceTransformPoints -scale '(0.001 0.001 0.001)' \
        constant/triSurface/part.stl constant/triSurface/part.stl > logs/scale.log 2>&1
    surfaceFeatureExtract > logs/extract.log 2>&1
    blockMesh > logs/blockMesh.log 2>&1
    snappyHexMesh -overwrite > logs/snappy.log 2>&1
else
    echo ">>> No STL, using blockMesh..."
    blockMesh > logs/blockMesh.log 2>&1
fi

# 4. Generate controlDict (Ensuring variables are not empty)
echo ">>> Writing controlDict with EndTime: $END_TIME"
cat <<EOF > system/controlDict
FoamFile { version 2.0; format ascii; class dictionary; location "system"; object controlDict; }
application     interFoam;
startFrom       startTime;
startTime       0;
stopAt          endTime;
endTime         ${END_TIME};
deltaT          1e-05;
adjustTimeStep  yes;
maxCo           0.2;
maxAlphaCo      0.2;
writeControl    adjustableRunTime;
writeInterval   0.05;
EOF

# Numerical Guard for schemes
sed -i 's/Gauss linear/Gauss upwind/g' system/fvSchemes

# 5. Solver Execution
echo ">>> Executing Solver (interFoam)..."
if interFoam > logs/solver.log 2>&1; then
    echo "✅ Success: Simulation finished."
else
    echo "❌ Error: interFoam crashed. Check logs/solver.log"
    exit 1 # This triggers Exit Code 1 in GitHub Actions
fi

# 6. Export
[ -d "postProcessing" ] && cp -r postProcessing results/ || echo "No post-data."
