#!/bin/bash
# set -e 제거 — 에러 직접 핸들링, 로그 끝까지 출력 보장

CASE_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$CASE_DIR"

# ── 파라미터 ──────────────────────────────
VELOCITY="${VELOCITY:-0.025}"
VISCOSITY="${VISCOSITY:-4e-3}"
DENSITY="${DENSITY:-7780}"
END_TIME="${END_TIME:-0.5}"
MELT_TEMP="${MELT_TEMP:-185}"
MOLD_TEMP="${MOLD_TEMP:-40}"
MATERIAL="${MATERIAL:-17-4PH}"

echo "========================================"
echo "[Allrun] 재료=${MATERIAL}"
echo "[Allrun] V=${VELOCITY} | nu=${VISCOSITY} | rho=${DENSITY}"
echo "[Allrun] Tmelt=${MELT_TEMP} | Tmold=${MOLD_TEMP} | T=${END_TIME}"
echo "========================================"

mkdir -p logs results system constant 0

# ── 이전 결과 정리 ────────────────────────
rm -rf processor* postProcessing VTK simulation_results.zip 2>/dev/null || true
find . -maxdepth 1 -regextype posix-extended \
  -regex '\./[0-9]+(\.[0-9]+)?' -not -name '0' \
  -type d -exec rm -rf {} + 2>/dev/null || true

PIPELINE_OK=true

# ══════════════════════════════════════════
# 설정 파일 생성
# ══════════════════════════════════════════

echo "[Allrun] 설정 파일 생성 시작..."

# ── controlDict ───────────────────────────
cat > system/controlDict << CTRL_EOF
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
application     interFoam;
startFrom       startTime;
startTime       0;
stopAt          endTime;
endTime         ${END_TIME};
deltaT          0.0001;
writeControl    adjustableRunTime;
writeInterval   0.05;
purgeWrite      0;
writeFormat     ascii;
writePrecision  6;
writeCompression off;
timeFormat      general;
timePrecision   6;
runTimeModifiable true;
adjustTimeStep  yes;
maxCo           0.5;
maxAlphaCo      0.5;
maxDeltaT       0.01;
// ************************************************************************* //
CTRL_EOF
echo "[Allrun] ✅ controlDict 생성"

# ── transportProperties ───────────────────
cat > constant/transportProperties << TP_EOF
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      transportProperties;
}
phases (water air);
water
{
    transportModel  Newtonian;
    nu              [0 2 -1 0 0 0 0] ${VISCOSITY};
    rho             [1 -3 0 0 0 0 0] ${DENSITY};
}
air
{
    transportModel  Newtonian;
    nu              [0 2 -1 0 0 0 0] 1.48e-5;
    rho             [1 -3 0 0 0 0 0] 1.2;
}
sigma           [1 0 -2 0 0 0 0] 0.4;
// ************************************************************************* //
TP_EOF
echo "[Allrun] ✅ transportProperties 생성"

# ── turbulenceProperties ──────────────────
cat > constant/turbulenceProperties << 'TURB_EOF'
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      turbulenceProperties;
}
simulationType  laminar;
// ************************************************************************* //
TURB_EOF
echo "[Allrun] ✅ turbulenceProperties 생성"

# ── g (중력) ──────────────────────────────
cat > constant/g << 'G_EOF'
FoamFile
{
    version     2.0;
    format      ascii;
    class       uniformDimensionedVectorField;
    location    "constant";
    object      g;
}
dimensions      [0 1 -2 0 0 0 0];
value           (0 -9.81 0);
// ************************************************************************* //
G_EOF
echo "[Allrun] ✅ g 생성"

# ── 0/p_rgh ───────────────────────────────
cat > 0/p_rgh << 'P_EOF'
FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      p_rgh;
}
dimensions      [1 -1 -2 0 0 0 0];
internalField   uniform 0;
boundaryField
{
    inlet        { type fixedFluxPressure; value uniform 0; }
    outlet       { type fixedValue; value uniform 0; }
    walls        { type fixedFluxPressure; value uniform 0; }
    frontAndBack { type empty; }
}
// ************************************************************************* //
P_EOF
echo "[Allrun] ✅ p_rgh 생성"

# ── 0/p ───────────────────────────────────
cat > 0/p << 'P2_EOF'
FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      p;
}
dimensions      [1 -1 -2 0 0 0 0];
internalField   uniform 0;
boundaryField
{
    inlet        { type calculated; value uniform 0; }
    outlet       { type calculated; value uniform 0; }
    walls        { type calculated; value uniform 0; }
    frontAndBack { type empty; }
}
// ************************************************************************* //
P2_EOF
echo "[Allrun] ✅ p 생성"

# ── 0/alpha.water ─────────────────────────
cat > 0/alpha.water << 'A_EOF'
FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      alpha.water;
}
dimensions      [0 0 0 0 0 0 0];
internalField   uniform 0;
boundaryField
{
    inlet        { type fixedValue; value uniform 1; }
    outlet       { type zeroGradient; }
    walls        { type zeroGradient; }
    frontAndBack { type empty; }
}
// ************************************************************************* //
A_EOF
echo "[Allrun] ✅ alpha.water 생성"

# ── 0/U ───────────────────────────────────
cat > 0/U << U_EOF
FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    location    "0";
    object      U;
}
dimensions      [0 1 -1 0 0 0 0];
internalField   uniform (0 0 0);
boundaryField
{
    inlet        { type fixedValue; value uniform (${VELOCITY} 0 0); }
    outlet       { type zeroGradient; }
    walls        { type noSlip; }
    frontAndBack { type empty; }
}
// ************************************************************************* //
U_EOF
echo "[Allrun] ✅ 0/U 생성"

# ── fvSchemes ─────────────────────────────
cat > system/fvSchemes << 'FS_EOF'
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSchemes;
}
ddtSchemes      { default Euler; }
gradSchemes     { default Gauss linear; }
divSchemes
{
    default                         none;
    div(phi,alpha.water)            Gauss vanLeer;
    div(phi,alpha)                  Gauss vanLeer;
    div(phirb,alpha.water)          Gauss linear;
    div(phirb,alpha)                Gauss linear;
    div(rhoPhi,U)                   Gauss linearUpwind grad(U);
    div(((rho*nuEff)*dev2(T(grad(U)))))  Gauss linear;
}
laplacianSchemes { default Gauss linear corrected; }
interpolationSchemes { default linear; }
snGradSchemes    { default corrected; }
fluxRequired     { default no; p_rgh; pcorr; alpha.water; }
// ************************************************************************* //
FS_EOF
echo "[Allrun] ✅ fvSchemes 생성"

# ── fvSolution ────────────────────────────
cat > system/fvSolution << 'FSO_EOF'
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
solvers
{
    "alpha.water.*"
    {
        cAlpha              1;
        nAlphaCorr          2;
        nAlphaSubCycles     1;
        nLimiterIter        3;
        MULESCorr           yes;
        alphaApplyPrevCorr  yes;
        solver              smoothSolver;
        smoother            symGaussSeidel;
        tolerance           1e-8;
        relTol              0;
    }
    "pcorr.*"
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-5;
        relTol          0;
    }
    p_rgh
    {
        solver          GAMG;
        smoother        DIC;
        tolerance       1e-7;
        relTol          0.05;
    }
    p_rghFinal
    {
        $p_rgh;
        relTol          0;
    }
    U
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;
        tolerance       1e-6;
        relTol          0;
        nSweeps         1;
    }
    UFinal
    {
        $U;
        relTol          0;
    }
}
PIMPLE
{
    momentumPredictor   no;
    nOuterCorrectors    1;
    nCorrectors         3;
    nNonOrthogonalCorrectors 0;
    pRefCell            0;
    pRefValue           0;
}
relaxationFactors { equations { ".*" 1; } }
// ************************************************************************* //
FSO_EOF
echo "[Allrun] ✅ fvSolution 생성"

echo "[Allrun] 모든 설정 파일 생성 완료"
echo "========================================"

# ══════════════════════════════════════════
# blockMesh
# ══════════════════════════════════════════
echo "[Allrun] blockMesh 실행..."
blockMesh 2>&1 | tee logs/blockMesh.log
BLOCKMESH_EXIT=${PIPESTATUS[0]}

if [ "$BLOCKMESH_EXIT" -ne 0 ]; then
    echo "[Allrun] ❌ blockMesh 실패 (exit=${BLOCKMESH_EXIT})"
    PIPELINE_OK=false
else
    echo "[Allrun] ✅ blockMesh 완료"
fi

# ══════════════════════════════════════════
# interFoam (blockMesh 성공 시만 실행)
# ══════════════════════════════════════════
if [ "$PIPELINE_OK" = true ]; then
    echo "[Allrun] interFoam 실행..."
    interFoam 2>&1 | tee logs/interFoam.log
    INTERFOAM_EXIT=${PIPESTATUS[0]}

    echo "========================================"
    echo "=== interFoam 마지막 30줄 ==="
    tail -30 logs/interFoam.log
    echo "========================================"

    if [ "$INTERFOAM_EXIT" -ne 0 ]; then
        echo "[Allrun] ❌ interFoam 실패 (exit=${INTERFOAM_EXIT})"
        PIPELINE_OK=false
    else
        echo "[Allrun] ✅ interFoam 완료"
    fi
else
    echo "[Allrun] ⏭️ blockMesh 실패로 interFoam 건너뜀"
fi

# ══════════════════════════════════════════
# 결과 검증 및 메타데이터
# ══════════════════════════════════════════
TIMESTEPS=$(find . -maxdepth 1 -regextype posix-extended -regex '\./[0-9]+\.[0-9]+' -type d 2>/dev/null | wc -l)
echo "[Allrun] 타임스텝 폴더: ${TIMESTEPS}개"

LAST_TIME=""
if [ "$TIMESTEPS" -gt 0 ]; then
    LAST_TIME=$(find . -maxdepth 1 -regextype posix-extended -regex '\./[0-9]+\.[0-9]+' -type d | sort -t. -k1,1n -k2,2n | tail -1 | sed 's/\.\///')
fi

# ══════════════════════════════════════════
# 🚀 웹 시각화 및 다운로드용 후처리 (Update)
# ══════════════════════════════════════════
echo "[Allrun] 후처리 시작: 웹 시각화 데이터 생성 중..."

if [ "$TIMESTEPS" -gt 0 ]; then
    # 1. ParaView 없이 웹에서 보기 위한 VTK 변환
    foamToVTK 2>&1 | tee logs/foamToVTK.log
    
    # 2. 결과 다운로드를 위한 압축 파일 생성
    # [0-9]* : 모든 시간 스텝 폴더 포함
    zip -r simulation_results.zip [0-9]* constant system case.foam VTK 2>/dev/null
    
    echo "[Allrun] ✅ VTK 변환 및 압축 완료 (simulation_results.zip)"
else
    echo "[Allrun] ⚠️ 결과 폴더가 없어 후처리를 건너뜁니다."
fi

# 메타데이터 기록
cat > results/meta.txt << META_EOF
MATERIAL=${MATERIAL}
VELOCITY=${VELOCITY}
VISCOSITY=${VISCOSITY}
DENSITY=${DENSITY}
MELT_TEMP=${MELT_TEMP}
MOLD_TEMP=${MOLD_TEMP}
END_TIME=${END_TIME}
LAST_TIME=${LAST_TIME}
TIMESTEPS=${TIMESTEPS}
PIPELINE_OK=${PIPELINE_OK}
ZIP_CREATED=$( [ -f simulation_results.zip ] && echo "true" || echo "false" )
META_EOF

echo "========================================"
if [ "$PIPELINE_OK" = true ] && [ "$TIMESTEPS" -gt 0 ]; then
    echo "[Allrun] ✅ 시뮬레이션 및 후처리 최종 성공"
    echo "[Allrun] 타임스텝: ${TIMESTEPS}개 | 마지막: ${LAST_TIME}"
else
    echo "[Allrun] ❌ 시뮬레이션 실패 또는 결과 없음"
fi
echo "========================================"

exit 0
