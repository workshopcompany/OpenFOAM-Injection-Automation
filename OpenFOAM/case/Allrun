#!/bin/bash
cd "${0%/*}" || exit

# 1. 초기화
echo "Cleaning old data..."
rm -rf [1-9]* 0.* log.* simulation.log screenshots
mkdir -p screenshots

# 2. 0 폴더 복구
if [ -d "0.orig" ]; then
    cp -r 0.orig 0
fi

# 3. 격자 및 해석
echo "Generating Mesh..."
blockMesh > log.blockMesh 2>&1
snappyHexMesh -overwrite > log.snappyHexMesh 2>&1

unset application
echo "Running interFoam..."
interFoam > simulation.log 2>&1

# 4. 후처리 (이 부분이 핵심입니다)
# 최신 타임스텝의 데이터를 읽기 위해 .foam 파일을 생성합니다.
touch case.foam

if [ -f "export_screenshots.py" ]; then
    echo "Running pvpython post-processing..."
    # xvfb-run은 가상 디스플레이를 제공하여 서버 환경에서 그래픽 작업을 가능하게 합니다.
    apt-get install -y xvfb > /dev/null 2>&1
    xvfb-run -a pvpython export_screenshots.py > log.pvpython 2>&1
else
    echo "Error: export_screenshots.py not found!"
fi

# 5. 결과 확인
ls -la screenshots/
