FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      T;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 1 0 0 0];

internalField   uniform 353.15;   // Mold temperature 80°C

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform 448.15;   // Nozzle temperature 175°C
    }

    outlet
    {
        type            zeroGradient;
    }

    "wall.*"
    {
        type            fixedValue;
        value           uniform 353.15;   // Mold temperature
    }

    atmosphere
    {
        type            inletOutlet;
        inletValue      uniform 300;
        value           uniform 300;
    }

    bottom
    {
        type            zeroGradient;
    }
}
