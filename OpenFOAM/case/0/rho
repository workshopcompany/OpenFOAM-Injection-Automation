/*--------------------------------*- C++ -*----------------------------------*\
FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      rho;
}
\*---------------------------------------------------------------------------*/

dimensions      [1 -3 0 0 0 0 0];

internalField   uniform 4500;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform 4500;
    }

    outlet
    {
        type            zeroGradient;
    }

    atmosphere
    {
        type            zeroGradient;
    }

    bottom
    {
        type            zeroGradient;
    }

    "wall.*"
    {
        type            zeroGradient;
    }
}

