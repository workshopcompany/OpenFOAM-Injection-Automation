FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      k;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 0.01; // 초기 난류 에너지 값

boundaryField
{
    inlet           { type fixedValue; value $internalField; }
    outlet          { type inletOutlet; inletValue $internalField; value $internalField; }
    atmosphere      { type inletOutlet; inletValue $internalField; value $internalField; }
    bottom          { type kqRWallFunction; value $internalField; }
    "wall.*"        { type kqRWallFunction; value $internalField; }
}
