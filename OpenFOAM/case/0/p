FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      p;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 -1 -2 0 0 0 0];

internalField   uniform 101325;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform 101325;
    }
    
    outlet
    {
        type            fixedValue;
        value           uniform 101325;
    }
    
    walls
    {
        type            zeroGradient;
    }
    
    atmosphere
    {
        type            totalPressure;
        p0              uniform 101325;
        value           uniform 101325;
    }
    
    bottom
    {
        type            zeroGradient;
    }
}

