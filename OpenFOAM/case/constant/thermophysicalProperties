FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      thermophysicalProperties;
}

thermoType
{
    type            heRhoThermo;
    mixture         pureMixture;
    transport       const;
    thermo          hConst;
    equationOfState rhoConst;
    specie          specie;
    energy          sensibleEnthalpy;
}

mixture
{
    specie
    {
        molWeight       100;
    }
    thermodynamics
    {
        Cp              500;
        Hf              0;
    }
    transport
    {
        mu              1.5;
        Pr              0.7;
    }
    equationOfState
    {
        rho             4500;
    }
}

