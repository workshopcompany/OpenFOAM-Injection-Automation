FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      thermophysicalProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

thermoType
{
    type            heRhoThermo;
    mixture         pureMixture;
    transport       const;
    thermo          hConst;
    equationOfState  rhoConst;
    specie          specie;
    energy          sensibleEnthalpy;
}

mixture
{
    specie
    {
        molWeight   100;
    }

    thermodynamics
    {
        Cp          500;      // Specific heat capacity [J/kg·K]
        Hf          0;
    }

    transport
    {
        mu          1.5;      // Dynamic viscosity [kg/m·s]
        Pr          0.7;      // Prandtl number
    }

    equationOfState
    {
        rho         4500;     // Density [kg/m³]
    }
}

