FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      transportProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

phases (water air);

water
{
    transportModel  Newtonian;
    nu              VISCOSITY_PLACEHOLDER;   // 런타임에 sed로 치환
    rho             1000;
}

air
{
    transportModel  Newtonian;
    nu              1.48e-5;
    rho             1;
}

sigma           0.07;   // 표면장력 [N/m] — MIM 슬러리 사용 시 조정 필요

