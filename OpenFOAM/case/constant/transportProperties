FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
application     simpleFoam;
startFrom       startTime;
startTime       0;
stopAt          endTime;
endTime         5;
deltaT          1;
writeControl    timeStep;
writeInterval   100;
purgeWrite      0;
writeFormat     ascii;
writePrecision  6;
writeCompression off;
controlDict:
    application: simpleFoam
    startFrom: startTime
    startTime: 0
    stopAt: endTime
    endTime: 5
    deltaT: 1
    writeControl: timeStep
    writeInterval: 100
    purgeWrite: 0
    writeFormat: ascii
    writePrecision: 6
    writeCompression: off
fvSchemes:
    ddtSchemes:
        default: Euler
    gradSchemes:
        default: Gauss linear
    divSchemes:
        default: none
        "div(phi,U)": Gauss linearUpwind
    laplacianSchemes:
        default: Gauss linear corrected
    interpolationSchemes:
        default: linear
    snGradSchemes:
        default: corrected
fvSolution:
    solvers:
        p:
            solver: PCG
            preconditioner: DIC
            tolerance: 1e-06
            relTol: 0.05
        U:
            solver: PBiCG
            preconditioner: DILU
            tolerance: 1e-06
            relTol: 0.05
transportProperties:
    transportModel: Newtonian
    nu: !!str 1e-06
    rho: !!str 900
