FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      transportProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
phases (water air);

water
{
    transportModel  Newtonian;
    nu              1e-06;
    rho             1000; // 물의 밀도
}
air
{
    transportModel  Newtonian;
    nu              1.48e-05;
    rho             1.2;  // 공기의 밀도
}

sigma           0.072; // 표면장력 계수
