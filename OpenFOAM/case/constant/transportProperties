FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      transportProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// [안전장치] 어떤 솔버가 실행되든 에러 없이 넘어가도록 최상단에 기본값 선언
transportModel  Newtonian;
nu              [0 2 -1 0 0 0 0] 1e-06;
rho             [1 -3 0 0 0 0 0] 1000;

// [다상 유동] 실제 interFoam이 읽어갈 물/공기 설정 (단위 완벽 명시)
phases (water air);

water
{
    transportModel  Newtonian;
    nu              [0 2 -1 0 0 0 0] 1e-06;
    rho             [1 -3 0 0 0 0 0] 1000;
}

air
{
    transportModel  Newtonian;
    nu              [0 2 -1 0 0 0 0] 1.48e-05;
    rho             [1 -3 0 0 0 0 0] 1.2;
}

sigma           [1 0 -2 0 0 0 0] 0.072;

