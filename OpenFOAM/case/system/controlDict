FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// ✅ 솔버 이름을 interFoam으로 정확히 지정합니다.
application     interFoam;

startFrom       startTime;
startTime       0;
stopAt          endTime;
endTime         5;

// 시간 간격 설정
deltaT          0.0001; 

// 다상 유동 해석의 수렴성을 위한 자동 시간 간격 조절
adjustTimeStep  yes;
maxCo           0.5;
maxAlphaCo      0.5; // interFoam(VOF) 해석의 핵심 안정성 지표

writeControl    timeStep;
writeInterval   100;
purgeWrite      0;
writeFormat     ascii;
writePrecision  6;
writeCompression off;

runTimeModifiable true;

// ************************************************************************* //
