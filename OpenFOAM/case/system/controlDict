FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     pimpleFoam;
startFrom       startTime;
startTime       0;
stopAt          endTime;
endTime         5;

// 시간 간격을 0.001에서 0.0001로 줄여서 안정성을 높입니다.
deltaT          0.0001; 

// Courant Number를 체크하여 자동으로 시간 간격을 조절하는 옵션 (강력 추천)
adjustTimeStep  yes;
maxCo           1.0;  // 안전빵으로 1.0 설정
maxDeltaT       1.0;

writeControl    timeStep;
writeInterval   100;
purgeWrite      0;
writeFormat     ascii;
writePrecision  6;
writeCompression off;

// ************************************************************************* //
