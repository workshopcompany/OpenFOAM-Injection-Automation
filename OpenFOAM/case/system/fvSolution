FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}

solvers
{
    "alpha.water.*"
    {
        interfaceMethod "isoAdvector";   // 또는 "MULES"
        isoFaceTol      1e-6;
        surfCellTol     1e-6;
        snapTol         1e-12;
        nAlphaBounds    3;
        clip            true;

        cAlpha          1;               // ← 이 줄이 핵심 (누락된 항목)
        nAlphaCorr      1;
        nAlphaSubCycles 2;

        MULESCorr       yes;
        nLimiterIter    3;

        solver          smoothSolver;
        smoother        symGaussSeidel;
        tolerance       1e-8;
        relTol          0;
    }

    p_rgh
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-7;
        relTol          0.05;
    }

    p_rghFinal
    {
        $p_rgh;
        relTol          0;
    }

    U
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;
        tolerance       1e-6;
        relTol          0;
    }
}
PIMPLE
{
    momentumPredictor no; // 초기 안정성을 위해 끕니다.
    nOuterCorrectors  3;
    nCorrectors       2;
    nNonOrthogonalCorrectors 0;
}
