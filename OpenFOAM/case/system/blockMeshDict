FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

scale   0.001;  // 밀리미터 → 미터 변환

vertices
(
    (0 0 0)      // 0
    (100 0 0)    // 1
    (100 50 0)   // 2
    (0 50 0)     // 3
    (0 0 10)     // 4
    (100 0 10)   // 5
    (100 50 10)  // 6
    (0 50 10)    // 7
);

blocks
(
    hex (0 1 2 3 4 5 6 7) (40 20 4) simpleGrading (1 1 1)
);

edges
(
);

boundary
(
    inlet
    {
        type patch;
        faces
        (
            (0 4 7 3)
        );
    }
    outlet
    {
        type patch;
        faces
        (
            (1 2 6 5)
        );
    }
    walls
    {
        type wall;
        faces
        (
            (0 1 5 4)
            (3 7 6 2)
        );
    }
    atmosphere
    {
        type patch;
        faces
        (
            (4 5 6 7)
        );
    }
    bottom
    {
        type wall;
        faces
        (
            (0 3 2 1)
        );
    }
);

mergePatchPairs
(
);

